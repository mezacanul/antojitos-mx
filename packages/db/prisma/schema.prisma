// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

generator zod {
  provider         = "zod-prisma-types"
  output           = "../../shared/generated/zod" // Points to your shared package
  createInputTypes = true // Useful for Mobile forms
  addIncludeType   = true
  addSelectType    = true
}

model Business {
  // Custom 
  name      String
  phone     String?
  email     String? @unique
  website   String? @unique
  address   String?
  city      String
  state     String
  country   String  @default("MX")
  zip       String?
  latitude  Float?
  longitude Float?
  timezone  String?
  rfc       String? @unique
  imageUrl  String?

  // System 
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenants           Tenant[]
  branches          Branch[]
  products          Product[]
  productCategories ProductCategory[]
  exchangeRates     ExchangeRate[]

  categories BusinessCategory[] // Implicit many-to-many
}

model Tenant {
  // Custom 
  // * Required for onboarding
  names            String
  maternal_surname String
  paternal_surname String
  email            String  @unique
  phone            String?

  rfc String? @unique

  // System 
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  users User[]
}

model Branch {
  // Custom 
  name      String
  latitude  Float
  longitude Float
  city      String
  state     String
  address   String?
  zip       String?
  imageUrl  String?
  // internal_code String  @unique

  // System 
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  users         User[]
  // products      Product[] // For branch-specific inventory/availability
  reviews       Reviews[]
  favorites     Favorites[]
  exchangeRates ExchangeRate[]
}

enum Role {
  SYSTEM_ADMIN
  TENANT_OWNER
  BRANCH_MANAGER
  GUEST
}

enum FavoriteType {
  BRANCH
  PRODUCT
}

model User {
  // System 
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Custom 
  names            String
  maternal_surname String
  paternal_surname String
  email            String  @unique
  phone            String?
  role             Role    @default(GUEST)

  // Relations
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  reviews   Reviews[]
  favorites Favorites[]
}

model Product {
  // System 
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Custom 
  name        String
  description String
  baseUnit    BaseUnit @default(piece)
  imageUrl    String?

  // Relations
  productCategoryId String?
  productCategory   ProductCategory? @relation(fields: [productCategoryId], references: [id])
  businessId        String
  business          Business         @relation(fields: [businessId], references: [id])
  // branchId          String?
  // branch            Branch?          @relation(fields: [branchId], references: [id])
  favorites         Favorites[]
  prices            Price[]
  productVariants   ProductVariant[]

  // Logical deletion for audit trails
  isDeleted Boolean @default(false)
  isActive  Boolean @default(true)
  // @@index([branchId])

  @@index([businessId])
}

model Reviews {
  // System 
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Custom 
  rating  Int
  comment String?

  // Relations
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])
  userId   String
  user     User   @relation(fields: [userId], references: [id])
}

model Favorites {
  // System 
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Custom 
  type FavoriteType @default(BRANCH)

  // Custom Relations
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])

  // System Relations
  userId String
  user   User   @relation(fields: [userId], references: [id])
}

enum BaseUnit {
  piece
  gr
  kg
  ml
  lt
  lb
  oz
  floz
  size
}

// 2. Business Categories (Marketplace level)
model BusinessCategory {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  businesses  Business[] // Implicit many-to-many
}

// 3. Product Categories (Merchant level)
model ProductCategory {
  id          String  @id @default(uuid())
  name        String
  description String?

  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  products Product[]

  @@unique([name, businessId])
}

// 4. Prices (Linked to Product)
model Price {
  id        String   @id @default(uuid())
  price     Float // e.g., 500 for "500 gr"
  quantity  Decimal? @default(1) @db.Decimal(10, 2)
  sizeLabel String?

  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@unique([productId, sizeLabel, quantity]) // safety against duplicates
  @@index([productId])
}

model ProductVariant {
  id        String  @id @default(uuid())
  name      String
  productId String
  product   Product @relation(fields: [productId], references: [id])

  sku      String? @unique
  stock    Int     @default(0)
  isActive Boolean @default(true)

  @@unique([productId, name])
  @@index([productId])
}

// 5. Currencies (Global Reference)
model Currency {
  id            String         @id @default(uuid())
  code          String         @unique // e.g., "MXN", "USD"
  active        Boolean        @default(true)
  exchangeRates ExchangeRate[]
}

// 6. Exchange Rates (Scoped to Business/Branch)
model ExchangeRate {
  id        String   @id @default(uuid())
  rate      Decimal  @db.Decimal(10, 4) // e.g., 17.5000
  updatedAt DateTime @updatedAt

  currencyId String
  currency   Currency @relation(fields: [currencyId], references: [id])

  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  // Optional: Specific rate per branch if needed
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  @@unique([currencyId, businessId, branchId])
}

model Country {
  code      String  @unique
  name      String
  phoneCode String?

  id     String  @id @default(uuid())
  states State[]
}

model State {
  code String
  name String

  id          String  @id @default(uuid())
  countryCode String
  country     Country @relation(fields: [countryCode], references: [code])
  cities      City[]

  @@index([countryCode])
}

model City {
  name String

  id      String @id @default(uuid())
  stateId String
  state   State  @relation(fields: [stateId], references: [id])

  @@unique([name, stateId])
  @@index([stateId])
}
