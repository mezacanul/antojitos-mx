// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client-js"
}

generator zod {
  provider         = "zod-prisma-types"
  output           = "../../shared/generated/zod" // Points to your shared package
  createInputTypes = true // Useful for Mobile forms
  addIncludeType   = true
  addSelectType    = true
}

model Business {
  // Custom 
  name String
  slug String  @unique
  rfc  String? @unique

  // System 
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenants  Tenant[]
  branches Branch[]
  products Product[]
}

model Tenant {
  // Custom 
  names            String
  maternal_surname String
  paternal_surname String
  rfc              String? @unique

  // System 
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  users User[]
}

model Branch {
  // Custom 
  id          String  @id @default(cuid())
  internal_id String  @unique
  name        String
  address     String?

  // System 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  users     User[]
  products  Product[] // For branch-specific inventory/availability
  reviews   Reviews[]
  favorites Favorites[]
}

enum Role {
  SYSTEM_ADMIN
  TENANT_OWNER
  BRANCH_MANAGER
  GUEST
}

enum FavoriteType {
  BRANCH
  PRODUCT
}

model User {
  // System 
  id        String   @id
  role      Role     @default(GUEST)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Custom 
  email            String @unique
  names            String
  maternal_surname String
  paternal_surname String

  // Relations
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  reviews   Reviews[]
  favorites Favorites[]
}

model Product {
  // System 
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Custom 
  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)

  // Relations
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  branchId   String?
  branch     Branch?  @relation(fields: [branchId], references: [id])

  // Logical deletion for audit trails
  isDeleted Boolean     @default(false)
  favorites Favorites[]
}

model Reviews {
  // System 
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Custom 
  rating  Int
  comment String?

  // Relations
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])
  userId   String
  user     User   @relation(fields: [userId], references: [id])
}

model Favorites {
  // System 
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Custom 
  type FavoriteType @default(BRANCH)

  // Custom Relations
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])

  // System Relations
  userId String
  user   User   @relation(fields: [userId], references: [id])
}
